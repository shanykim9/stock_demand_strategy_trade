# Kiwoom API credentials
APP_KEY="YOUR_APP_KEY"
APP_SECRET="YOUR_APP_SECRET"
KIWOOM_ACCOUNT_NO=0000-0000-00

# Trading mode
# 1: dry-run (no live order), 0: live order mode
KIWOOM_DRY_RUN=1
KIWOOM_ENABLE_LIVE_TRADING=NO

# Market/session settings (KRX regular market)
KIWOOM_DMST_STEX_TP=KRX
KIWOOM_MARKET_OPEN=09:00
KIWOOM_LIVE_ORDER_START=09:00
KIWOOM_POLL_SEC=2.0
